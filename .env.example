# ─────────────────────────────────────────────────────────────────────────────
# DocSeva – environment variable reference
# Copy this file to .env and fill in the values.
# NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-long-random-secret

# Local dev: True. Production: False (REQUIRED)
DEBUG=True

# Comma-separated. Add your domain in production, e.g. myapp.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Comma-separated. Must include https:// prefix in production.
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: leave empty to use SQLite
# Production: postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=
DATABASE_SSL_REQUIRE=False
DB_CONN_MAX_AGE=600
DB_CONN_HEALTH_CHECKS=True

# ── Cache / Sessions ─────────────────────────────────────────────────────────
# Local dev: leave empty (uses in-memory cache + db sessions)
# Production: redis://HOST:6379/0
REDIS_URL=

# ── Static / media ───────────────────────────────────────────────────────────
STATIC_ROOT=staticfiles
MEDIA_ROOT=media

# ── Email ─────────────────────────────────────────────────────────────────────
# Local dev: console backend prints emails to terminal
# Production: use smtp.EmailBackend with a real SMTP service (SendGrid, Mailgun etc.)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=DocSeva <noreply@yourdomain.com>
SERVER_EMAIL=docseva-errors@yourdomain.com
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=10

# Comma-separated admin emails that receive 500-error notifications (prod only)
# ADMINS=admin@example.com

# ── Security (leave defaults for local dev) ───────────────────────────────────
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
USE_X_FORWARDED_HOST=False
SESSION_COOKIE_AGE=86400
SESSION_EXPIRE_AT_BROWSER_CLOSE=False

# Set True to log CSP violations without blocking (good for initial rollout)
CSP_REPORT_ONLY=False

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATELIMIT_ENABLE=True

# ── Password reset ────────────────────────────────────────────────────────────
# Token lifetime in seconds (1 hour = 3600)
PASSWORD_RESET_TIMEOUT=3600

# ── Uploads ───────────────────────────────────────────────────────────────────
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
DATA_UPLOAD_MAX_MEMORY_SIZE=15728640

# ── External integrations ────────────────────────────────────────────────────
# "mock" uses fake responses; set to "live" when connected to real NHA APIs
GOV_API_MODE=mock

# Optional absolute base URL for QR/share links.
# Local LAN example: http://192.168.1.10:8000
# Render example: https://docseva.onrender.com
PUBLIC_BASE_URL=
SECURITY_CONTACT=mailto:security@example.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Gunicorn ─────────────────────────────────────────────────────────────────
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
GUNICORN_MAX_REQUESTS=1200
GUNICORN_MAX_REQUESTS_JITTER=200
# ── Admin hardening ──────────────────────────────────────────────────────────
# Change this before production. Must end with / after parsing.
ADMIN_URL=secure-admin/

# ── Sentry monitoring ────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0

# ── Celery background tasks ──────────────────────────────────────────────────
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240

# ── Optional S3-compatible media storage ─────────────────────────────────────
USE_S3_MEDIA=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=True
