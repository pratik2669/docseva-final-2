# DocSeva Render production environment reference
# Do not commit real values. Put these in Render Dashboard > Environment.

DEBUG=False
SECRET_KEY=<Render can generate this automatically>
ALLOWED_HOSTS=<your-service-name>.onrender.com
CSRF_TRUSTED_ORIGINS=https://<your-service-name>.onrender.com
DATABASE_URL=<Render Postgres internal connection string>
REDIS_URL=<Render Redis internal connection string>
DATABASE_SSL_REQUIRE=True
SECURE_SSL_REDIRECT=True
USE_X_FORWARDED_HOST=True

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=<smtp-host>
EMAIL_PORT=587
EMAIL_HOST_USER=<smtp-user>
EMAIL_HOST_PASSWORD=<smtp-password-or-api-key>
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=DocSeva <noreply@yourdomain.com>
SERVER_EMAIL=DocSeva Errors <noreply@yourdomain.com>
ADMINS=admin@yourdomain.com

GOV_API_MODE=mock

# Optional but recommended for generated QR/share links.
PUBLIC_BASE_URL=https://<your-service-name>.onrender.com
RATELIMIT_ENABLE=True
LOG_LEVEL=INFO
# ── Admin hardening ──────────────────────────────────────────────────────────
# Change this before production. Must end with / after parsing.
ADMIN_URL=secure-admin/

# ── Sentry monitoring ────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0

# ── Celery background tasks ──────────────────────────────────────────────────
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240

# ── Optional S3-compatible media storage ─────────────────────────────────────
USE_S3_MEDIA=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=True
