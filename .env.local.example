# DocSeva local development environment
# Copy this file to .env for local runs:
#   cp .env.local.example .env

SECRET_KEY=dev-only-local-docseva-key-change-before-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Local SQLite. Leave DATABASE_URL empty locally.
DATABASE_URL=
DATABASE_SSL_REQUIRE=False

# Local password-reset testing writes emails to terminal.
# Production must use smtp backend + real SMTP credentials.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=DocSeva Local <noreply@docseva.local>
SERVER_EMAIL=DocSeva Local <noreply@docseva.local>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=10

# Keep government integrations mocked locally until official API clients exist.
GOV_API_MODE=mock

# For QR scan from another phone on the same Wi-Fi, set this to your laptop LAN URL.
# Find IP: hostname -I | awk '{print $1}'
# Example: PUBLIC_BASE_URL=http://192.168.1.10:8000
PUBLIC_BASE_URL=
SECURITY_CONTACT=mailto:security@example.com

RATELIMIT_ENABLE=False
SECURE_SSL_REDIRECT=False
USE_X_FORWARDED_HOST=False
LOG_LEVEL=INFO
# ── Admin hardening ──────────────────────────────────────────────────────────
# Change this before production. Must end with / after parsing.
ADMIN_URL=secure-admin/

# ── Sentry monitoring ────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0

# ── Celery background tasks ──────────────────────────────────────────────────
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240

# ── Optional S3-compatible media storage ─────────────────────────────────────
USE_S3_MEDIA=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=True
